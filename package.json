{
  "name": "@mon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/website",
    "apps/agent",
    "apps/docs",
    "packages/db",
    "packages/config",
    "packages/contracts",
    "packages/test-utils"
  ],
  "scripts": {
    "format:check": "bunx prettier --check .",
    "format:write": "bunx prettier --write .",
    "lint": "bun run lint:tsc && bun run lint:website && bun run lint:docs",
    "lint:docs": "cd apps/docs && bun run lint",
    "lint:tsc": "bunx tsc --noEmit",
    "lint:website": "cd apps/website && bun run lint"
  },
  "overrides": {
    "@xmldom/xmldom": ">=0.9.9",
    "ajv": "^6.14.0",
    "brace-expansion": ">=1.1.12",
    "dompurify": ">=3.2.7",
    "drizzle-orm": ">=0.45.2",
    "esbuild": ">=0.25.0",
    "flatted": ">=3.4.0",
    "js-yaml": ">=4.1.1",
    "lodash": ">=4.17.23",
    "lodash-es": ">=4.17.23",
    "mdast-util-to-hast": ">=13.2.1",
    "mermaid": ">=11.15.0",
    "minimatch": ">=3.1.3",
    "picomatch": ">=2.3.2",
    "postcss": ">=8.5.10",
    "smol-toml": ">=1.6.1",
    "tar": ">=7.5.7",
    "uuid": ">=11.1.1",
    "yaml": ">=2.8.3"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "ts5.8",
    "@typescript-eslint/typescript-estree": "^8.25.0",
    "bun-types": "^1.3.14",
    "prettier": "^3.5.3",
    "prettier-plugin-packagejson": "^2.5.10",
    "prettier-plugin-tailwindcss": "^0.6.11"
  },
  "patchedDependencies": {
    "nextra-theme-docs@4.6.1": "patches/nextra-theme-docs@4.6.1.patch"
  }
}
